# Shopify Storefront API
# Create a custom app in Shopify Admin: Settings > Apps and sales channels > Develop apps > Create an app
# Enable Storefront API access and copy the Storefront API access token
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=stoney-maloney-usa.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_token_here

# Firebase (optional - for client-side Firebase features like Auth)
# Get config from Firebase Console > Project settings > General
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=stoney-maloney
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
