<section class="real-results">
  <div class="real-results__inner">
    <h2 class="real-results__title">{{ section.settings.heading }}</h2>
    <p class="real-results__subtitle">{{ section.settings.subtitle }}</p>
    <div class="real-results__grid">
      {% for block in section.blocks %}
        <div class="real-results__item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="real-results__media">
              {{ block.settings.image | image_url: width: 400 | image_tag }}
            </div>
          {% endif %}
          <h3 class="real-results__item-title">{{ block.settings.title }}</h3>
          <p class="real-results__item-desc">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Real Results",
  "class": "section-real-results",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Results"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Where Stoney Maloney shines"
    }
  ],
  "blocks": [
    {
      "type": "use_case",
      "name": "Use case",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Real Results",
      "blocks": [
        {
          "type": "use_case",
          "settings": {
            "title": "Athlete Recovery",
            "description": "Soothe muscles and skin after intense workouts."
          }
        },
        {
          "type": "use_case",
          "settings": {
            "title": "Dry Skin Repair",
            "description": "Restore moisture to parched, irritated skin."
          }
        },
        {
          "type": "use_case",
          "settings": {
            "title": "Lips & Hydration",
            "description": "Keep lips soft and nourished year-round."
          }
        },
        {
          "type": "use_case",
          "settings": {
            "title": "Natural Skincare Routine",
            "description": "Simple, honest skincare with real ingredients."
          }
        }
      ]
    }
  ]
}
{% endschema %}
