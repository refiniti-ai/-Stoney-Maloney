{% comment %}
  Sticky scroll story: full-viewport crossfade (Savor StoryCanvas-inspired, GSAP-driven).
{% endcomment %}
<section
  class="story-parallax"
  id="story-parallax"
  style="min-height: {{ section.settings.scroll_vh }}vh;"
  data-story-section
  data-nav-theme="light"
>
  <div class="story-parallax__pin">
    <div class="story-parallax__media" aria-hidden="true">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'slide' %}
            <div class="story-parallax__layer" data-story-layer {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 2400 | image_tag: loading: 'lazy', sizes: '100vw', widths: '800, 1200, 1600, 2400' }}
              {% else %}
                <img src="{{ 'hero-product.png' | asset_url }}" alt="" width="800" height="800">
              {% endif %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
    <div class="story-parallax__shade"></div>
    <div class="story-parallax__text">
      {% if section.settings.heading != blank %}
        <h2 class="fluid-display reveal-mask">
          <span class="reveal-mask__inner">{{ section.settings.heading }}</span>
        </h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="fluid-lead">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story parallax",
  "class": "section-story-parallax",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "scroll_vh",
      "min": 220,
      "max": 500,
      "step": 10,
      "unit": "vh",
      "label": "Scroll height",
      "default": 320,
      "info": "Taller = longer crossfade scroll (desktop motion)."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From pasture to jar"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Grass-fed tallow, slow-rendered and blended with care—skincare that honors tradition."
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Image slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Story parallax",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
