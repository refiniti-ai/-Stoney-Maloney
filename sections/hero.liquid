<section class="hero hero--stoney" data-nav-theme="light" style="--hero-bg: {{ section.settings.background }}; --hero-text: {{ section.settings.text_color }};">
  {% if section.settings.pattern_opacity > 0 and section.settings.pattern_image != blank %}
    <div class="hero__pattern" data-parallax-speed="0.12" style="opacity: {{ section.settings.pattern_opacity | divided_by: 100.0 }};">
      {{ section.settings.pattern_image | image_url: width: 400 | image_tag: class: 'hero__pattern-img' }}
    </div>
  {% endif %}

  {% assign shop_words = section.settings.button_shop_label | split: ' ' %}
  {% assign learn_words = section.settings.button_learn_label | split: ' ' %}
  {% assign shop_first = shop_words | first %}
  {% assign learn_first = learn_words | first %}
  {% capture shop_right %}{% for w in shop_words offset: 1 %}{{ w }}{% unless forloop.last %} {% endunless %}{% endfor %}{% endcapture %}
  {% capture learn_right %}{% for w in learn_words offset: 1 %}{{ w }}{% unless forloop.last %} {% endunless %}{% endfor %}{% endcapture %}

  <div class="hero__inner">
    <div class="hero__content" data-parallax-speed="-0.05">
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
      <div class="hero__buttons">
        <a href="{{ section.settings.button_shop_url | default: '/collections/all' }}" class="hero__btn hero__btn--primary btn-savor btn-magnetic">
          <span class="btn-savor__word btn-savor__word--left">{{ shop_first }}</span>
          {% if shop_right != blank %}
            <span class="btn-savor__dash" aria-hidden="true"></span>
            <span class="btn-savor__word btn-savor__word--right">{{ shop_right }}</span>
          {% endif %}
        </a>
        <a href="{{ section.settings.button_learn_url | default: '#what-is-tallow' }}" class="hero__btn hero__btn--secondary btn-savor btn-magnetic">
          <span class="btn-savor__word btn-savor__word--left">{{ learn_first }}</span>
          {% if learn_right != blank %}
            <span class="btn-savor__dash" aria-hidden="true"></span>
            <span class="btn-savor__word btn-savor__word--right">{{ learn_right }}</span>
          {% endif %}
        </a>
      </div>
    </div>
    <div class="hero__product hero__zoom-wrap">
      <div class="hero__zoom-inner">
        {% if section.settings.product_image != blank %}
          {{ section.settings.product_image | image_url: width: 800 | image_tag: class: 'hero__product-img', loading: 'eager', widths: '400, 600, 800' }}
        {% else %}
          <img src="{{ 'hero-product.png' | asset_url }}" alt="Miracle Recovery Rub" class="hero__product-img" width="500">
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "class": "section-hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nature's Healing Power, Refined."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tallow-based skincare designed to nourish, restore, and soothe."
    },
    {
      "type": "text",
      "id": "button_shop_label",
      "label": "Shop button label",
      "default": "Shop Products"
    },
    {
      "type": "url",
      "id": "button_shop_url",
      "label": "Shop button link"
    },
    {
      "type": "text",
      "id": "button_learn_label",
      "label": "Learn button label",
      "default": "Learn About Tallow"
    },
    {
      "type": "url",
      "id": "button_learn_url",
      "label": "Learn button link"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Hero product image"
    },
    {
      "type": "image_picker",
      "id": "pattern_image",
      "label": "Background pattern (from packaging)"
    },
    {
      "type": "range",
      "id": "pattern_opacity",
      "min": 0,
      "max": 30,
      "step": 5,
      "default": 0,
      "unit": "%",
      "label": "Pattern opacity"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#E85D04"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FDF8F3"
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
