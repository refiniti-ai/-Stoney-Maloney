<section class="hero" style="--hero-height: {{ section.settings.height }}px; --hero-bg: {{ section.settings.background }}; --hero-text: {{ section.settings.text_color }};">
  <div class="hero__inner">
    {% if section.settings.heading != blank %}
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {% endif %}
    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="hero__button">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>

  {% if section.settings.image != blank %}
    <div class="hero__image-wrapper">
      {{ section.settings.image | image_url: width: 1920 | image_tag: loading: 'eager', class: 'hero__image', widths: '375, 550, 750, 1100, 1500, 1920' }}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Hero",
  "class": "section-hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Stoney Maloney USA"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Quality products for you"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "height",
      "min": 300,
      "max": 800,
      "step": 50,
      "default": 500,
      "unit": "px",
      "label": "Section height"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
