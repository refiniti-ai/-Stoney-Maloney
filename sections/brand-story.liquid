<section class="brand-story">
  <div class="brand-story__inner">
    <div class="brand-story__content">
      <h2 class="brand-story__title">{{ section.settings.heading }}</h2>
      <div class="brand-story__body rte">{{ section.settings.body }}</div>
      <ul class="brand-story__values">
        {% if section.settings.value1 != blank %}<li>{{ section.settings.value1 }}</li>{% endif %}
        {% if section.settings.value2 != blank %}<li>{{ section.settings.value2 }}</li>{% endif %}
        {% if section.settings.value3 != blank %}<li>{{ section.settings.value3 }}</li>{% endif %}
        {% if section.settings.value4 != blank %}<li>{{ section.settings.value4 }}</li>{% endif %}
      </ul>
    </div>
    <div class="brand-story__logo">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 300 | image_tag: class: 'brand-story__logo-img' }}
      {% else %}
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="brand-story__logo-img" width="200">
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "class": "section-brand-story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Story",
      "default": "<p>A simple mission to bring back traditional skincare made with real ingredients. We focus on natural ingredients, small-batch production, and honest skincare—healing first.</p>"
    },
    {
      "type": "text",
      "id": "value1",
      "label": "Value 1",
      "default": "Natural ingredients"
    },
    {
      "type": "text",
      "id": "value2",
      "label": "Value 2",
      "default": "Small-batch production"
    },
    {
      "type": "text",
      "id": "value3",
      "label": "Value 3",
      "default": "Honest skincare"
    },
    {
      "type": "text",
      "id": "value4",
      "label": "Value 4",
      "default": "Healing first"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}
