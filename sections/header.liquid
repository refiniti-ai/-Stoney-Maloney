<header class="header header--stoney header--nav-aware" role="banner" data-nav-theme="light">
  <div class="header__inner">
    <a href="{{ routes.root_url }}" class="header__logo">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 200 | image_tag: class: 'header__logo-img', loading: 'eager', widths: '120, 200' }}
      {% else %}
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="header__logo-img" width="140">
      {% endif %}
    </a>

    <nav class="header__nav" role="navigation">
      <ul class="header__nav-list">
        {% for link in linklists[section.settings.menu].links %}
          <li><a href="{{ link.url }}" class="header__nav-link">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </nav>

    <div class="header__actions">
      <a href="{{ routes.cart_url }}" class="header__cart" aria-label="Cart">
        Cart ({{ cart.item_count }})
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Upload logo or leave blank to use default"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
