<section class="benefits" data-nav-theme="dark">
  <div class="benefits__inner">
    <h2 class="benefits__title reveal-mask">
      <span class="reveal-mask__inner">{{ section.settings.heading }}</span>
    </h2>
    <div class="benefits__grid">
      {% for block in section.blocks %}
        <div class="benefits__item card card-hover" {{ block.shopify_attributes }}>
          <div class="benefits__icon">
            {% if block.settings.icon != blank %}
              {{ block.settings.icon | image_url: width: 80 | image_tag }}
            {% else %}
              <span class="benefits__icon-placeholder">{{ block.settings.icon_fallback }}</span>
            {% endif %}
          </div>
          <h3 class="benefits__item-title">{{ block.settings.title }}</h3>
          <p class="benefits__item-desc">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits of Tallow",
  "class": "section-benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Benefits of Tallow"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "icon_fallback",
          "label": "Fallback emoji/symbol",
          "default": "✦"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Deep Skin Nourishment",
            "description": "Rich in Vitamins A, D, E, and K for radiant, healthy skin.",
            "icon_fallback": "✦"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Soothes Irritation",
            "description": "Calms sensitive skin and supports natural healing.",
            "icon_fallback": "◆"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Supports Natural Barrier",
            "description": "Helps maintain your skin's protective moisture barrier.",
            "icon_fallback": "◇"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Chemical-Free Moisturizing",
            "description": "Real ingredients. No fillers. Just pure nourishment.",
            "icon_fallback": "●"
          }
        }
      ]
    }
  ]
}
{% endschema %}
